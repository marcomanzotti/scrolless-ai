<?xml version="1.0" encoding="utf-8"?>
<!-- DEMO ONLY: allow plain HTTP to the local backend during development.
     10.0.2.2 is the Android emulator's alias for the host machine (your Mac).
     In production the backend is HTTPS, so this whole file can be removed. -->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">localhost</domain>
    </domain-config>
</network-security-config>
